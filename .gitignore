# --- Environment & secrets (never commit real env files) ---
.env
.env.*
!.env.example
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# Allow committed templates only
!backend/.env.example
!frontend/.env.example

# Common local overrides
*.env.local
backend/*.env.local
frontend/*.env.local

# --- Dependencies ---
node_modules/
backend/node_modules/
frontend/node_modules/

# --- Build outputs ---
dist/
backend/dist/
frontend/dist/
build/
*.tsbuildinfo

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Test & coverage ---
coverage/
.nyc_output/

# --- Caches ---
.cache/
.turbo/

# --- OS ---
.DS_Store
Thumbs.db

# --- Backend: generated benchmark output ---
backend/outputs/
